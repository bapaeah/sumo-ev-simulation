<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Vehicle Types for EVs with different battery capacities -->
    <vType id="ev_40kwh" vClass="electric" emissionClass="Energy/unknown" length="5" minGap="2.5" maxSpeed="20" accel="2" decel="2" sigma="0.5">
        <param key="battery" value="40" />
        <param key="maximumBatteryCapacity" value="40" />
        <param key="consumptionRate" value="0.15" />
    </vType>
    
    <vType id="ev_50kwh" vClass="electric" emissionClass="Energy/unknown" length="5" minGap="2.5" maxSpeed="20" accel="2" decel="2" sigma="0.5">
        <param key="battery" value="50" />
        <param key="maximumBatteryCapacity" value="50" />
        <param key="consumptionRate" value="0.15" />
    </vType>
    
    <vType id="ev_55kwh" vClass="electric" emissionClass="Energy/unknown" length="5" minGap="2.5" maxSpeed="20" accel="2" decel="2" sigma="0.5">
        <param key="battery" value="55" />
        <param key="maximumBatteryCapacity" value="55" />
        <param key="consumptionRate" value="0.15" />
    </vType>
    
    <vType id="ev_60kwh" vClass="electric" emissionClass="Energy/unknown" length="5" minGap="2.5" maxSpeed="20" accel="2" decel="2" sigma="0.5">
        <param key="battery" value="60" />
        <param key="maximumBatteryCapacity" value="60" />
        <param key="consumptionRate" value="0.15" />
    </vType>
    
    <vType id="ev_75kwh" vClass="electric" emissionClass="Energy/unknown" length="5" minGap="2.5" maxSpeed="20" accel="2" decel="2" sigma="0.5">
        <param key="battery" value="75" />
        <param key="maximumBatteryCapacity" value="75" />
        <param key="consumptionRate" value="0.15" />
    </vType>
    
    <!-- Traffic vehicles (background vehicles) -->
    <vType id="traffic_car" vClass="passenger" emissionClass="Euro4" length="5" minGap="2.5" maxSpeed="18" accel="2.5" decel="2.5" sigma="0.8" />
    
    <!-- Pedestrians -->
    <personFlow id="pedestrian_flow" begin="0" end="600" number="15" type="DEFAULT_PEDTYPE">
        <walk edges="marathalli_ped marathalli whitefield_ped" />
    </personFlow>
    
    <personFlow id="pedestrian_flow2" begin="0" end="600" number="12" type="DEFAULT_PEDTYPE">
        <walk edges="whitefield_ped whitefield silk_ped" />
    </personFlow>
    
    <!-- EV 1: 40 kWh battery, 80% SOC (32 kWh) -->
    <vehicle id="ev_01" type="ev_40kwh" depart="0" departPos="0" departSpeed="max">
        <route edges="marathalli_etv_main whitefield_silk silk_etv etv_silk silk_whitefield whitefield_marathalli" />
        <param key="initialSOC" value="80" />
    </vehicle>
    
    <!-- EV 2: 60 kWh battery, 85% SOC (51 kWh) -->
    <vehicle id="ev_02" type="ev_60kwh" depart="2" departPos="0" departSpeed="max">
        <route edges="marathalli_etv_main whitefield_silk silk_etv etv_silk silk_whitefield whitefield_marathalli" />
        <param key="initialSOC" value="85" />
    </vehicle>
    
    <!-- EV 3: 75 kWh battery, 90% SOC (67.5 kWh) -->
    <vehicle id="ev_03" type="ev_75kwh" depart="4" departPos="0" departSpeed="max">
        <route edges="marathalli_etv_main whitefield_silk silk_etv etv_silk silk_whitefield whitefield_marathalli" />
        <param key="initialSOC" value="90" />
    </vehicle>
    
    <!-- EV 4: 50 kWh battery, 70% SOC (35 kWh) -->
    <vehicle id="ev_04" type="ev_50kwh" depart="6" departPos="0" departSpeed="max">
        <route edges="marathalli_etv_main whitefield_silk silk_etv etv_silk silk_whitefield whitefield_marathalli" />
        <param key="initialSOC" value="70" />
    </vehicle>
    
    <!-- EV 5: 55 kWh battery, 75% SOC (41.25 kWh) -->
    <vehicle id="ev_05" type="ev_55kwh" depart="8" departPos="0" departSpeed="max">
        <route edges="marathalli_etv_main whitefield_silk silk_etv etv_silk silk_whitefield whitefield_marathalli" />
        <param key="initialSOC" value="75" />
    </vehicle>
    
    <!-- Traffic vehicles to create congestion -->
    <flow id="traffic_flow_1" type="traffic_car" begin="0" end="600" vehsPerHour="600" departPos="random">
        <route edges="marathalli_etv_main whitefield_silk silk_etv" />
    </flow>
    
    <flow id="traffic_flow_2" type="traffic_car" begin="0" end="600" vehsPerHour="500" departPos="random">
        <route edges="etv_silk silk_whitefield whitefield_marathalli" />
    </flow>
    
    <flow id="traffic_flow_3" type="traffic_car" begin="0" end="600" vehsPerHour="400" departPos="random">
        <route edges="marathalli_etv_main whitefield_silk silk_etv" />
    </flow>
</routes>
