<?xml version="1.0" encoding="UTF-8"?>
<edges xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/edges_file.xsd">
    <!-- Main highway edges -->
    <edge id="marathalli_whitefield" from="marathalli" to="whitefield" priority="10" numLanes="3" speed="15.0" />
    <edge id="whitefield_silk" from="whitefield" to="silk_board" priority="10" numLanes="3" speed="12.0" />
    <edge id="silk_etv" from="silk_board" to="etv_junction" priority="10" numLanes="3" speed="10.0" />
    
    <!-- Return edges -->
    <edge id="etv_silk" from="etv_junction" to="silk_board" priority="10" numLanes="3" speed="10.0" />
    <edge id="silk_whitefield" from="silk_board" to="whitefield" priority="10" numLanes="3" speed="12.0" />
    <edge id="whitefield_marathalli" from="whitefield" to="marathalli" priority="10" numLanes="3" speed="15.0" />
    
    <!-- Pedestrian edges -->
    <edge id="marathalli_ped_in" from="marathalli_ped" to="marathalli" priority="-1" numLanes="1" speed="1.4" allow="pedestrian" />
    <edge id="marathalli_ped_out" from="marathalli" to="marathalli_ped" priority="-1" numLanes="1" speed="1.4" allow="pedestrian" />
    <edge id="whitefield_ped_in" from="whitefield_ped" to="whitefield" priority="-1" numLanes="1" speed="1.4" allow="pedestrian" />
    <edge id="whitefield_ped_out" from="whitefield" to="whitefield_ped" priority="-1" numLanes="1" speed="1.4" allow="pedestrian" />
    <edge id="silk_ped_in" from="silk_ped" to="silk_board" priority="-1" numLanes="1" speed="1.4" allow="pedestrian" />
    <edge id="silk_ped_out" from="silk_board" to="silk_ped" priority="-1" numLanes="1" speed="1.4" allow="pedestrian" />
</edges>
